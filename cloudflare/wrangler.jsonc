{
  "name": "storyloop",
  "main": "src/entry.py",
  "compatibility_date": "2026-02-24",
  "compatibility_flags": ["python_workers"],
  "workers_dev": false,
  "routes": [
    {
      "pattern": "mystoryloop.com/*",
      "zone_name": "mystoryloop.com"
    }
  ],
  "assets": {
    "directory": "../frontend/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*",
      "/diagnostics/*",
      "/cloud/*",
      "/health",
      "/assets/blob*"
    ]
  },
  "vars": {
    "APP_ENV": "dev",
    "MODEL_PROBE_BASE_URL": "https://api.openai.com/v1",
    "MODEL_PROBE_MODEL": "gpt-4o-mini"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "storyloop-app",
      "database_id": "5ad1cb25-862e-48cf-91ce-fa8bc2fff984",
      "migrations_dir": "migrations"
    }
  ]
}
